# Email Configuration
# Gunakan SMTP dari email provider (Gmail, SendGrid, Mailgun, etc)

# Untuk Gmail:
# 1. Enable 2FA di Google Account
# 2. Generate App Password di https://myaccount.google.com/apppasswords
# 3. Gunakan app password di EMAIL_PASSWORD

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO_RECEIVE=your-email@gmail.com

# Alternatif SMTP providers:
# SendGrid: smtp.sendgrid.net, port 587
# Mailgun: smtp.mailgun.org, port 587
# Brevo: smtp-relay.brevo.com, port 587
